# Dependencies
vendor/
node_modules/

# Generated images (cached locally, not committed)
public_html/images/generated/scenes/*.png
public_html/images/generated/npcs/*.png
public_html/images/generated/monsters/*.png
public_html/images/generated/items/*.png
public_html/images/generated/towns/*.png
public_html/images/generated/dungeons/*.png
public_html/images/generated/maps/*.png

# Generated world data (regenerated on deploy)
# database/world.json is intentionally committed as a placeholder

# Log files (runtime data – stored above public_html, never in the repo)
logs/*.log

# PHP error logs
*.error_log
error_log

# Sensitive config overrides
config.local.php

# Keep config.php, database/, and engine/ at repo root (outside public_html)
# These must NEVER appear inside public_html/
public_html/config.php
public_html/config.local.php
public_html/engine/
public_html/database/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
